# Configuration Backend UNIHOME
# Copiez ce fichier en .env et remplissez les valeurs

# Port du serveur
PORT=3001

# Environnement
NODE_ENV=development

# Secret JWT (IMPORTANT: Changez-le en production!)
JWT_SECRET=votre-secret-jwt-tres-securise-changez-moi-en-production

# Secret pour les sessions Express
SESSION_SECRET=votre-secret-session-tres-securise-changez-moi

# URL du frontend (pour les redirections CORS et OAuth)
FRONTEND_URL=http://localhost:5090

# URL du backend (pour le callback Google OAuth)
BACKEND_URL=http://localhost:3001

# Google OAuth (Optionnel - pour la connexion Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
